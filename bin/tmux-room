#!/usr/bin/env bash
set -eo pipefail

TMUX_ROOM_VERSION="0.3.0"
TMUX_ROOM_RAW_URL="${TMUX_ROOM_RAW_URL:-https://raw.githubusercontent.com/enoteware/tmux-room/main/bin/tmux-room}"
TMUX_ROOM_CONFIG_DIR="${TMUX_ROOM_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/tmux-room}"
TMUX_ROOM_HOSTS_FILE="${TMUX_ROOM_HOSTS_FILE:-$TMUX_ROOM_CONFIG_DIR/hosts}"

usage() {
  cat <<'EOF'
tmux-room — device-aware tmux agent room picker

Usage:
  tmux-room                       Arrow-key picker (Enter inspect, x close, q quit)
  tmux-room <name>                Attach to a local room
  tmux-room device:room           Attach to a room on a configured device
  tmux-room --list                Show compact local room table
  tmux-room --all                 Show compact local and SSH-device tables
  tmux-room --kill <room>         Inspect and double-confirm killing a local room
  tmux-room --kill device:room    Double-confirm killing a configured remote room
  tmux-room --version             Print the installed version
  tmux-room --update              Update from the public GitHub repository
  tmux-room --help                Show this help

Host registry:
  ~/.config/tmux-room/hosts

Format (one device per line):
  mini elliot@mini.example.internal
  devbox hostinger-vps

Set a friendly local name in ~/.config/tmux-room/device or TMUX_ROOM_DEVICE.
Detach from tmux with Ctrl-b then d.
EOF
}

sanitize_text() {
  printf '%s' "$1" | python3 -c 'import sys, unicodedata; s=sys.stdin.read(); sys.stdout.write("".join(ch for ch in s if ch.isprintable() and not unicodedata.category(ch).startswith("C")))'
}

get_device_name() {
  if [[ -n "${TMUX_ROOM_DEVICE:-}" ]]; then
    printf '%s' "$TMUX_ROOM_DEVICE"
  elif [[ -s "$TMUX_ROOM_CONFIG_DIR/device" ]]; then
    sed -n '1p' "$TMUX_ROOM_CONFIG_DIR/device"
  elif command -v scutil >/dev/null 2>&1; then
    scutil --get ComputerName 2>/dev/null || hostname -s
  else
    hostname -s 2>/dev/null || hostname
  fi
}

format_date() {
  TMUX_ROOM_FORMAT_DATE=1 TMUX_ROOM_EPOCH="$1" python3 - <<'PY'
from datetime import datetime
import os
try:
    print(datetime.fromtimestamp(int(os.environ['TMUX_ROOM_EPOCH'])).strftime('%Y-%m-%d %H:%M'))
except (ValueError, OSError, OverflowError):
    print('unknown')
PY
}

server_status() {
  TMUX_ROOM_SERVER_STATUS=1 python3 - <<'PY'
import os
import platform
import re
import shutil
import subprocess

try:
    load = os.getloadavg()[0]
    cores = os.cpu_count() or 1
    cpu_pct = round(load / cores * 100)
except (AttributeError, OSError):
    load, cores, cpu_pct = 0.0, 1, 0

try:
    if platform.system() == 'Darwin':
        sysctl = shutil.which('sysctl') or '/usr/sbin/sysctl'
        vm_stat = shutil.which('vm_stat') or '/usr/bin/vm_stat'
        total = int(subprocess.run([sysctl, '-n', 'hw.memsize'], capture_output=True, text=True, check=True).stdout.strip())
        vm_text = subprocess.run([vm_stat], capture_output=True, text=True, check=True).stdout
        size_match = re.search(r'page size of (\d+) bytes', vm_text)
        page_size = int(size_match.group(1)) if size_match else 4096
        values = {name: int(value) for name, value in re.findall(r'^([^:]+):\s+(\d+)\.', vm_text, re.M)}
        available_pages = sum(values.get(name, 0) for name in ('Pages free', 'Pages inactive', 'Pages speculative'))
        available = available_pages * page_size
    else:
        page_size = os.sysconf('SC_PAGE_SIZE')
        total = os.sysconf('SC_PHYS_PAGES') * page_size
        available = os.sysconf('SC_AVPHYS_PAGES') * page_size
    used = max(0, total - available)
    ram_pct = round(used / total * 100) if total else 0
    used_gb = used / (1024 ** 3)
    total_gb = total / (1024 ** 3)
    ram = f'RAM {ram_pct}% ({used_gb:.1f}/{total_gb:.1f} GB)'
except (ValueError, OSError):
    ram = 'RAM unavailable'

print(f'CPU {cpu_pct}% load ({load:.2f}/{cores}) · {ram}')
PY
}

version_is_newer() {
  TMUX_ROOM_CURRENT_VERSION="$TMUX_ROOM_VERSION" TMUX_ROOM_LATEST_VERSION="$1" python3 - <<'PY'
import os

def parts(value):
    value = value.lstrip('v')
    return tuple(int(piece) for piece in value.split('.'))

try:
    raise SystemExit(0 if parts(os.environ['TMUX_ROOM_LATEST_VERSION']) > parts(os.environ['TMUX_ROOM_CURRENT_VERSION']) else 1)
except (KeyError, ValueError):
    raise SystemExit(1)
PY
}

check_for_update() {
  local cache_file="$TMUX_ROOM_CONFIG_DIR/update-check" now checked_at latest response tmp
  [[ "${TMUX_ROOM_DISABLE_UPDATE_CHECK:-0}" == "1" ]] && return 0
  command -v curl >/dev/null 2>&1 || return 0
  now=$(date +%s)
  checked_at=""
  latest=""
  if [[ -r "$cache_file" ]]; then
    IFS='|' read -r checked_at latest < "$cache_file" || true
  fi
  if [[ ! "$checked_at" =~ ^[0-9]+$ ]] || ((now - checked_at >= 86400)); then
    response=$(curl --connect-timeout 1 --max-time 2 -fsSL 'https://api.github.com/repos/enoteware/tmux-room/releases/latest' 2>/dev/null || true)
    latest=$(printf '%s' "$response" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("tag_name", ""))' 2>/dev/null || true)
    if [[ "$latest" =~ ^v?[0-9]+(\.[0-9]+){1,3}$ ]]; then
      mkdir -p "$TMUX_ROOM_CONFIG_DIR" 2>/dev/null || true
      tmp="$cache_file.$$"
      if printf '%s|%s\n' "$now" "$latest" > "$tmp" 2>/dev/null; then
        mv "$tmp" "$cache_file" 2>/dev/null || rm -f "$tmp"
      fi
    else
      latest=""
    fi
  fi
  if [[ -n "$latest" ]] && version_is_newer "$latest"; then
    printf 'UPDATE: %s available · run tmux-room --update\n\n' "$latest"
  fi
}

agent_scan() {
  local roots="$1" hints="$2" compact="${3:-0}"
  TMUX_ROOM_AGENT_SCAN=1 TMUX_ROOM_COMPACT_AGENT_SCAN="$compact" TMUX_ROOM_ROOT_PIDS="$roots" TMUX_ROOM_PANE_HINTS="$hints" python3 - <<'PY'
import os
import re
import subprocess

roots = []
for raw in os.environ.get('TMUX_ROOM_ROOT_PIDS', '').split(','):
    try:
        roots.append(int(raw))
    except ValueError:
        pass
hints = os.environ.get('TMUX_ROOM_PANE_HINTS', '')
compact = os.environ.get('TMUX_ROOM_COMPACT_AGENT_SCAN') == '1'

rows = []
raw_ps = subprocess.run(
    ['ps', '-eo', 'pid=,ppid=,args='], capture_output=True, text=True, check=False
).stdout
for line in raw_ps.splitlines():
    parts = line.strip().split(None, 2)
    if len(parts) == 3:
        try:
            rows.append((int(parts[0]), int(parts[1]), parts[2]))
        except ValueError:
            pass

children = {}
args_by_pid = {}
for pid, ppid, args in rows:
    children.setdefault(ppid, []).append(pid)
    args_by_pid[pid] = args

def identify(args):
    low = args.lower()
    if 'tmux-room' in low:
        return None
    if re.search(r'(^|[/\s])claude(?:\s|$)', low) or '/@anthropic-ai/claude-code' in low:
        return 'Claude'
    if re.search(r'(^|[/\s])codex(?:\s|$)', low) or 'codex-aarch64' in low:
        return 'Codex'
    if re.search(r'(^|[/\s])grok(?:\s|$)', low) or re.search(r'(^|[/\s])xai(?:\s|$)', low):
        return 'Grok'
    if re.search(r'(^|[/\s])gemini(?:\s|$)', low):
        return 'Gemini'
    return None

def model_from(args, agent):
    patterns = [
        r'(?:--model|-m)[=\s]+([A-Za-z0-9._:/-]+)',
        r'\b((?:gpt|claude|grok|gemini)-[A-Za-z0-9._-]+)\b',
    ]
    for pattern in patterns:
        match = re.search(pattern, args, re.I)
        if match:
            return match.group(1)
    return 'model unknown'

def effort_from(args):
    patterns = [
        r'(?:--effort)[=\s]+([A-Za-z0-9._-]+)',
        r'(?:model_reasoning_effort|reasoning_effort)[=\s]+["\x27]?([A-Za-z0-9._-]+)',
    ]
    for pattern in patterns:
        match = re.search(pattern, args, re.I)
        if match:
            return match.group(1).lower()
    return 'unknown'

def elapsed(pid):
    value = subprocess.run(
        ['ps', '-p', str(pid), '-o', 'etime='], capture_output=True, text=True, check=False
    ).stdout.strip()
    return value.replace(' ', '') or 'unknown'

def started_at(pid):
    value = subprocess.run(
        ['ps', '-p', str(pid), '-o', 'lstart='], capture_output=True, text=True, check=False,
        env=dict(os.environ, LC_ALL='C')
    ).stdout.strip()
    try:
        from datetime import datetime
        return datetime.strptime(' '.join(value.split()), '%a %b %d %H:%M:%S %Y').strftime('%Y-%m-%d %H:%M')
    except (ValueError, TypeError):
        return 'unknown'

found = []
seen_pids = set()
queue = list(roots)
while queue:
    pid = queue.pop(0)
    if pid in seen_pids:
        continue
    seen_pids.add(pid)
    args = args_by_pid.get(pid, '')
    agent = identify(args)
    if agent:
        timing = ('unknown', 'unknown') if compact else (elapsed(pid), started_at(pid))
        found.append((agent, model_from(args, agent), timing[0], timing[1], effort_from(args)))
    queue.extend(children.get(pid, []))

# Pane command/title hints are a fallback when the process tree is momentarily sparse.
for hint in hints.split('||'):
    agent = identify(hint)
    if agent and not any(item[0] == agent for item in found):
        found.append((agent, model_from(hint, agent), 'unknown', 'unknown', effort_from(hint)))

unique = []
seen = set()
for item in found:
    key = (item[0], item[1])
    if key not in seen:
        seen.add(key)
        unique.append(item)
for item in unique:
    print('\t'.join(item))
PY
}

resource_scan() {
  TMUX_ROOM_RESOURCE_SCAN=1 TMUX_ROOM_ROOT_PIDS="$1" python3 - <<'PY'
import os
import subprocess

roots = []
for raw in os.environ.get('TMUX_ROOM_ROOT_PIDS', '').split(','):
    try:
        roots.append(int(raw))
    except ValueError:
        pass

rows = []
ps_result = subprocess.run(
    ['ps', '-eo', 'pid=,ppid=,rss='], capture_output=True, text=True, check=False
)
if ps_result.returncode != 0:
    print('unavailable\tunavailable')
    raise SystemExit(0)
for line in ps_result.stdout.splitlines():
    parts = line.strip().split()
    if len(parts) == 3:
        try:
            rows.append((int(parts[0]), int(parts[1]), int(parts[2])))
        except ValueError:
            pass

children = {}
rss_by_pid = {}
for pid, ppid, rss in rows:
    children.setdefault(ppid, []).append(pid)
    rss_by_pid[pid] = rss

seen = set()
queue = list(roots)
while queue:
    pid = queue.pop(0)
    if pid in seen or pid not in rss_by_pid:
        continue
    seen.add(pid)
    queue.extend(children.get(pid, []))

total_kb = sum(rss_by_pid.get(pid, 0) for pid in seen)
total_mb = (total_kb + 1023) // 1024
print(f'{total_mb}\t{len(seen)}')
PY
}

load_rows() {
  rows=()
  while IFS= read -r row; do
    [[ -n "$row" ]] && rows+=("$row")
  done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_created}|#{session_activity}|#{session_id}' 2>/dev/null | sort -t'|' -k1,1)
}

session_details() {
  local name="$1" windows="$2" attached="$3" created="$4" activity="$5" session_id="$6" index="$7"
  local status display_name pid path command title roots hints first_path repo_names branches top branch
  local agent_lines agent name_model age started effort agent_summary opened active window_word
  local resource_line memory_mb process_count memory_flag resource_available

  [[ "$attached" == "0" ]] && status="detached" || status="attached"
  [[ "$windows" == "1" ]] && window_word="window" || window_word="windows"

  roots=""
  hints=""
  first_path=""
  repo_names=""
  branches=""
  while IFS='|' read -r pid path command title; do
    [[ -z "$pid" ]] && continue
    roots="${roots:+$roots,}$pid"
    hints="${hints:+$hints||}$command $title"
    [[ -z "$first_path" ]] && first_path="$path"
    if top=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null); then
      name_model=$(basename "$top")
      case ",$repo_names," in *",$name_model,"*) ;; *) repo_names="${repo_names:+$repo_names, }$name_model" ;; esac
      branch=$(git -C "$path" branch --show-current 2>/dev/null || true)
      [[ -z "$branch" ]] && branch="detached@$(git -C "$path" rev-parse --short HEAD 2>/dev/null || echo unknown)"
      case ",$branches," in *",$branch,"*) ;; *) branches="${branches:+$branches, }$branch" ;; esac
    fi
  done < <(tmux list-panes -s -t "$session_id" -F '#{pane_pid}|#{pane_current_path}|#{pane_current_command}|#{pane_title}' 2>/dev/null)

  agent_lines=$(agent_scan "$roots" "$hints")
  agent_summary=""
  while IFS=$'\t' read -r agent name_model age started effort; do
    [[ -z "$agent" ]] && continue
    [[ -z "$effort" || "$effort" == "unknown" ]] && effort="unknown"
    agent_summary="${agent_summary:+$agent_summary; }$agent · $name_model · effort $effort · started $started · running $age"
  done <<<"$agent_lines"
  [[ -z "$agent_summary" ]] && agent_summary="none detected"

  resource_line=$(resource_scan "$roots")
  IFS=$'\t' read -r memory_mb process_count <<<"$resource_line"
  resource_available=0
  memory_flag=""
  if [[ "$memory_mb" =~ ^[0-9]+$ && "$process_count" =~ ^[0-9]+$ ]]; then
    resource_available=1
    if ((memory_mb >= 4096)); then
      memory_flag=" [HIGH]"
    elif ((memory_mb >= 1024)); then
      memory_flag=" [ELEVATED]"
    fi
  fi

  opened=$(format_date "$created")
  active=$(format_date "$activity")
  [[ -z "$repo_names" ]] && repo_names="not a Git repo"
  [[ -z "$branches" ]] && branches="n/a"
  [[ -z "$first_path" ]] && first_path="unknown"

  display_name=$(sanitize_text "$name")
  repo_names=$(sanitize_text "$repo_names")
  branches=$(sanitize_text "$branches")
  first_path=$(sanitize_text "$first_path")
  agent_summary=$(sanitize_text "$agent_summary")

  printf '  ROOM: %s [%s] · %s %s · #%s\n' "$display_name" "$status" "$windows" "$window_word" "$index"
  printf '    AGENTS: %s\n' "$agent_summary"
  printf '    OPENED: %s · LAST ACTIVE: %s\n' "$opened" "$active"
  printf '    REPO: %s · BRANCH: %s\n' "$repo_names" "$branches"
  if ((resource_available == 1)); then
    printf '    SUMMED RSS SNAPSHOT: %s MB%s · PROCESSES SNAPSHOT: %s\n' "$memory_mb" "$memory_flag" "$process_count"
  else
    printf '    RESOURCE SNAPSHOT: unavailable\n'
  fi
  printf '    CONTEXT: unavailable (agent CLI does not expose it safely)\n'
  printf '    PATH: %s\n' "$first_path"
}

load_compact_agent_inventory() {
  local pane_rows session_id label
  compact_agent_ids=()
  compact_agent_labels=()
  pane_rows=$(tmux list-panes -a -F '#{session_id}|#{pane_pid}|#{pane_current_command}|#{pane_title}' 2>/dev/null || true)
  while IFS=$'\t' read -r session_id label; do
    [[ -z "$session_id" ]] && continue
    compact_agent_ids+=("$session_id")
    compact_agent_labels+=("$label")
  done < <(TMUX_ROOM_AGENT_INVENTORY=1 TMUX_ROOM_PANE_ROWS="$pane_rows" python3 - <<'PY'
import os
import re
import subprocess

panes = {}
for line in os.environ.get('TMUX_ROOM_PANE_ROWS', '').splitlines():
    parts = line.split('|', 3)
    if len(parts) != 4:
        continue
    sid, raw_pid, command, title = parts
    try:
        pid = int(raw_pid)
    except ValueError:
        continue
    panes.setdefault(sid, []).append((pid, f'{command} {title}'))

ps_rows = []
result = subprocess.run(['ps', '-eo', 'pid=,ppid=,args='], capture_output=True, text=True, check=False)
for line in result.stdout.splitlines():
    parts = line.strip().split(None, 2)
    if len(parts) == 3:
        try:
            ps_rows.append((int(parts[0]), int(parts[1]), parts[2]))
        except ValueError:
            pass
children = {}
args_by_pid = {}
for pid, ppid, args in ps_rows:
    children.setdefault(ppid, []).append(pid)
    args_by_pid[pid] = args

def identify(args):
    low = args.lower()
    if 'tmux-room' in low:
        return None
    checks = [
        ('claude', r'(^|[/\s])claude(?:\s|$)|/@anthropic-ai/claude-code'),
        ('codex', r'(^|[/\s])codex(?:\s|$)|codex-aarch64'),
        ('grok', r'(^|[/\s])(?:grok|xai)(?:\s|$)'),
        ('gemini', r'(^|[/\s])gemini(?:\s|$)'),
    ]
    for provider, pattern in checks:
        if re.search(pattern, low):
            return provider
    return None

def field(args, patterns, default):
    for pattern in patterns:
        match = re.search(pattern, args, re.I)
        if match:
            return match.group(1).lower()
    return default

def label(args, provider):
    model = field(args, [r'(?:--model|-m)[=\s]+([A-Za-z0-9._:/-]+)', r'\b((?:gpt|claude|grok|gemini|fable)-?[A-Za-z0-9._-]+)\b'], 'unknown')
    effort = field(args, [r'--effort[=\s]+([A-Za-z0-9._-]+)', r'(?:model_reasoning_effort|reasoning_effort)[=\s]+["\x27]?([A-Za-z0-9._-]+)'], 'unknown')
    if model.startswith('claude-'):
        model = model[len('claude-'):]
    model = model.replace('-', '')
    return '-'.join(part for part in (provider, model, effort) if part != 'unknown') or 'none'

for sid, pane_items in panes.items():
    found = None
    queue = [pid for pid, _ in pane_items]
    seen = set()
    while queue and not found:
        pid = queue.pop(0)
        if pid in seen:
            continue
        seen.add(pid)
        args = args_by_pid.get(pid, '')
        provider = identify(args)
        if provider:
            found = label(args, provider)
            break
        queue.extend(children.get(pid, []))
    if not found:
        for _, hint in pane_items:
            provider = identify(hint)
            if provider:
                found = label(hint, provider)
                break
    print(f'{sid}\t{found or "none"}')
PY
  )
}

compact_agent_label() {
  local wanted="$1" i
  for i in "${!compact_agent_ids[@]}"; do
    if [[ "${compact_agent_ids[i]}" == "$wanted" ]]; then
      printf '%s' "${compact_agent_labels[i]}"
      return 0
    fi
  done
  printf 'none'
}

print_local_rooms() {
  local source_label="${1:-local}" device i name windows attached created activity session_id status display_name last_active agent_label status_line
  device=$(sanitize_text "$(get_device_name)")
  source_label=$(sanitize_text "$source_label")
  status_line=$(sanitize_text "$(server_status)")
  printf 'DEVICE: %s [%s]\n' "$device" "$source_label"
  printf 'STATUS: %s\n' "$status_line"
  if ! tmux has-session 2>/dev/null; then
    echo '  No tmux rooms are running.'
    return 0
  fi
  load_rows
  if ((${#rows[@]} == 0)); then
    echo '  No tmux rooms are running.'
    return 0
  fi
  load_compact_agent_inventory
  printf '  #  %-28s %-24s %-9s %7s  %s\n' 'ROOM' 'PROVIDER/MODEL' 'STATE' 'WINDOWS' 'LAST ACTIVE'
  printf '  -- %-28s %-24s --------- -------  ----------------\n' '----------------------------' '------------------------'
  for i in "${!rows[@]}"; do
    IFS='|' read -r name windows attached created activity session_id <<<"${rows[$i]}"
    [[ "$attached" == "0" ]] && status="detached" || status="attached"
    display_name=$(sanitize_text "$name")
    agent_label=$(compact_agent_label "$session_id")
    last_active=$(format_date "$activity")
    printf '  %-2d %-28s %-24s %-9s %7s  %s\n' "$((i+1))" "$display_name" "$agent_label" "$status" "$windows" "$last_active"
  done
  return 0
}

print_room_details() {
  local room="$1" row name windows attached created activity session_id index
  load_rows
  index=0
  for row in "${rows[@]}"; do
    index=$((index + 1))
    IFS='|' read -r name windows attached created activity session_id <<<"$row"
    [[ "$name" == "$room" ]] || continue
    echo "ROOM DETAILS"
    selected_session_id="$session_id"
    session_details "$name" "$windows" "$attached" "$created" "$activity" "$session_id" "$index"
    return 0
  done
  echo "Room not found: $room" >&2
  return 1
}

kill_local_room() {
  local room="$1" row name windows attached created activity session_id confirm final found
  local current_identity roots pid final_resource final_memory final_processes
  [[ "$room" =~ ^[A-Za-z0-9._-]+$ ]] || { echo "Invalid room name." >&2; return 2; }
  if ! tmux has-session -t "=$room" 2>/dev/null; then
    echo "Room not found: $room" >&2
    return 1
  fi

  load_rows
  found=0
  for row in "${rows[@]}"; do
    IFS='|' read -r name windows attached created activity session_id <<<"$row"
    [[ "$name" == "$room" ]] || continue
    echo "Room selected for termination:"
    session_details "$name" "$windows" "$attached" "$created" "$activity" "$session_id" 1
    found=1
    break
  done
  ((found == 1)) || { echo "Unable to inspect room: $room" >&2; return 1; }

  echo
  echo "WARNING: Killing this room asks tmux to terminate the session and its panes."
  echo "Detached, daemonized, reparented, or signal-ignoring processes may survive."
  if ! read -r -p "Confirmation 1/2 — type the exact room name ($room): " confirm || [[ "$confirm" != "$room" ]]; then
    echo "Kill cancelled."
    return 0
  fi
  if ! read -r -p "Confirmation 2/2 — type KILL: " final || [[ "$final" != "KILL" ]]; then
    echo "Kill cancelled."
    return 0
  fi

  current_identity=$(tmux display-message -p -t "=$room" '#{session_id}|#{session_name}' 2>/dev/null || true)
  if [[ "$current_identity" != "$session_id|$room" ]]; then
    echo "Kill aborted: room identity changed after inspection."
    return 1
  fi

  roots=""
  while IFS= read -r pid; do
    [[ -n "$pid" ]] && roots="${roots:+$roots,}$pid"
  done < <(tmux list-panes -s -t "$session_id" -F '#{pane_pid}' 2>/dev/null)
  final_resource=$(resource_scan "$roots")
  IFS=$'\t' read -r final_memory final_processes <<<"$final_resource"
  if [[ "$final_memory" =~ ^[0-9]+$ && "$final_processes" =~ ^[0-9]+$ ]]; then
    echo "Final best-effort snapshot: summed RSS $final_memory MB · processes $final_processes"
  else
    echo "Final resource snapshot: unavailable"
  fi

  current_identity=$(tmux display-message -p -t "=$room" '#{session_id}|#{session_name}' 2>/dev/null || true)
  if [[ "$current_identity" != "$session_id|$room" ]]; then
    echo "Kill aborted: room identity changed during final snapshot."
    return 1
  fi

  tmux kill-session -t "$session_id"
  echo "Killed room: $room"
}

valid_host_field() {
  [[ -n "$1" && "$1" != -* && "$1" =~ ^[A-Za-z0-9._@:-]+$ ]]
}

lookup_host() {
  local wanted="$1" label target rest
  [[ -f "$TMUX_ROOM_HOSTS_FILE" ]] || return 1
  while read -r label target rest || [[ -n "$label" ]]; do
    [[ -z "$label" || "$label" == \#* ]] && continue
    [[ -z "$rest" ]] || return 1
    [[ "$label" == "$wanted" ]] || continue
    valid_host_field "$label" && valid_host_field "$target" || return 1
    printf '%s' "$target"
    return 0
  done < "$TMUX_ROOM_HOSTS_FILE"
  return 1
}

print_all_devices() {
  local label target rest safe_label
  print_local_rooms local
  [[ -f "$TMUX_ROOM_HOSTS_FILE" ]] || return 0
  command -v ssh >/dev/null 2>&1 || { echo "tmux-room requires ssh for remote inventory." >&2; return 127; }
  while read -r label target rest || [[ -n "$label" ]]; do
    [[ -z "$label" || "$label" == \#* ]] && continue
    safe_label=$(sanitize_text "$label")
    if [[ -n "$rest" ]] || ! valid_host_field "$label" || ! valid_host_field "$target"; then
      echo
      echo "DEVICE: $safe_label [invalid host entry]"
      continue
    fi
    [[ "$label" == "$(get_device_name)" ]] && continue
    echo
    if ! ssh -o BatchMode=yes -o ConnectTimeout=6 "$target" "TMUX_ROOM_DEVICE=$label TMUX_ROOM_SOURCE_LABEL=remote tmux-room --list"; then
      echo "DEVICE: $label [unreachable]"
    fi
  done < "$TMUX_ROOM_HOSTS_FILE"
}

self_update() {
  local self tmp downloader
  self="${BASH_SOURCE[0]}"
  if [[ ! -w "$self" ]]; then
    echo "Cannot update $self: file is not writable." >&2
    exit 1
  fi
  tmp=$(mktemp "${TMPDIR:-/tmp}/tmux-room.XXXXXX")
  trap 'rm -f "$tmp"' EXIT
  if command -v curl >/dev/null 2>&1; then
    downloader=(curl -fsSL "$TMUX_ROOM_RAW_URL" -o "$tmp")
  elif command -v wget >/dev/null 2>&1; then
    downloader=(wget -qO "$tmp" "$TMUX_ROOM_RAW_URL")
  else
    echo "tmux-room update requires curl or wget." >&2
    exit 1
  fi
  "${downloader[@]}"
  bash -n "$tmp"
  grep -q '^TMUX_ROOM_VERSION=' "$tmp"
  chmod 755 "$tmp"
  mv "$tmp" "$self"
  trap - EXIT
  echo "Updated tmux-room: $($self --version)"
}

arrow_picker() {
  local selected=0 key rest i name windows attached created activity session_id status status_line
  local -a picker_names picker_windows picker_statuses picker_active picker_agents
  while true; do
    load_rows
    ((${#rows[@]} > 0)) || { echo 'No tmux rooms are running.'; return 1; }
    ((selected < ${#rows[@]})) || selected=$((${#rows[@]} - 1))
    picker_names=()
    picker_windows=()
    picker_statuses=()
    picker_active=()
    picker_agents=()
    load_compact_agent_inventory
    for i in "${!rows[@]}"; do
      IFS='|' read -r name windows attached created activity session_id <<<"${rows[$i]}"
      [[ "$attached" == "0" ]] && status="detached" || status="attached"
      picker_names[i]=$(sanitize_text "$name")
      picker_windows[i]="$windows"
      picker_statuses[i]="$status"
      picker_active[i]=$(format_date "$activity")
      picker_agents[i]=$(compact_agent_label "$session_id")
    done

    while true; do
      printf '\033[2J\033[H'
    printf 'DEVICE: %s [local]\n' "$(sanitize_text "$(get_device_name)")"
    status_line=$(sanitize_text "$(server_status)")
    printf 'STATUS: %s\n' "$status_line"
    printf 'Use ↑/↓ to move · Enter inspect/attach · x close · q quit\n\n'
    printf '  #  %-28s %-24s %-9s %7s  %s\n' 'ROOM' 'PROVIDER/MODEL' 'STATE' 'WINDOWS' 'LAST ACTIVE'
    printf '  -- %-28s %-24s --------- -------  ----------------\n' '----------------------------' '------------------------'
    for i in "${!rows[@]}"; do
      if ((i == selected)); then printf '\033[7m'; fi
      printf '  %-2d %-28s %-24s %-9s %7s  %s' "$((i+1))" "${picker_names[i]}" "${picker_agents[i]}" "${picker_statuses[i]}" "${picker_windows[i]}" "${picker_active[i]}"
      if ((i == selected)); then printf '\033[0m'; fi
      printf '\n'
    done

    IFS= read -rsn1 key || return 1
    if [[ "$key" == $'\033' ]]; then
      rest=""
      IFS= read -rsn2 rest || true
      case "$rest" in
        '[A') if ((selected > 0)); then selected=$((selected - 1)); fi ;;
        '[B') if ((selected + 1 < ${#rows[@]})); then selected=$((selected + 1)); fi ;;
      esac
      continue
    fi
    case "$key" in
      q|Q) return 1 ;;
      x|X)
        target="${picker_names[selected]}"
        printf '\033[0m\n'
        kill_local_room "$target"
        break
        ;;
      '')
        target="${picker_names[selected]}"
        return 0
        ;;
    esac
    done
  done
}

require_local_dependencies() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux-room requires tmux for local room inventory." >&2
    exit 127
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "tmux-room requires Python 3.7+ for agent detection." >&2
    exit 127
  fi
  if ! python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 7) else 1)' 2>/dev/null; then
    echo "tmux-room requires Python 3.7+ for agent detection." >&2
    exit 127
  fi
}

case "${1:-}" in
  --version|-V) echo "tmux-room $TMUX_ROOM_VERSION"; exit 0 ;;
  --help|-h) usage; exit 0 ;;
  --update) self_update; exit 0 ;;
esac

# Remote kill runs the same double-confirmation flow on the destination host.
if [[ "${1:-}" == "--kill" && "${2:-}" == *:* ]]; then
  device=${2%%:*}
  target=${2#*:}
  if ! valid_host_field "$device" || [[ ! "$target" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Invalid device or room name." >&2
    exit 2
  fi
  remote=$(lookup_host "$device") || { echo "Device not found in $TMUX_ROOM_HOSTS_FILE: $device" >&2; exit 1; }
  command -v ssh >/dev/null 2>&1 || { echo "tmux-room requires ssh for remote termination." >&2; exit 127; }
  exec ssh -t "$remote" tmux-room --kill "$target"
fi

# Remote attachment needs SSH only; it does not require local tmux or Python.
if [[ "${1:-}" == *:* ]]; then
  device=${1%%:*}
  target=${1#*:}
  if ! valid_host_field "$device" || [[ ! "$target" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Invalid device or room name." >&2
    exit 2
  fi
  remote=$(lookup_host "$device") || { echo "Device not found in $TMUX_ROOM_HOSTS_FILE: $device" >&2; exit 1; }
  command -v ssh >/dev/null 2>&1 || { echo "tmux-room requires ssh for remote attachment." >&2; exit 127; }
  echo "Attaching to $target on $device. Detach with Ctrl-b then d."
  exec ssh -t "$remote" tmux-room "$target"
fi

require_local_dependencies

case "${1:-}" in
  --all) print_all_devices; exit 0 ;;
  --list|-l) print_local_rooms "${TMUX_ROOM_SOURCE_LABEL:-local}"; exit 0 ;;
  --kill)
    [[ $# -eq 2 ]] || { echo "Usage: tmux-room --kill <room|device:room>" >&2; exit 2; }
    kill_local_room "$2"
    exit $?
    ;;
esac

if ! tmux has-session 2>/dev/null; then
  print_local_rooms local
  exit 0
fi
load_rows
if ((${#rows[@]} == 0)); then
  print_local_rooms local
  exit 0
fi

selected_session_id=""
if [[ $# -gt 0 ]]; then
  target="$1"
else
  check_for_update
  if [[ -t 0 && -t 1 || "${TMUX_ROOM_FORCE_ARROW:-0}" == "1" ]]; then
    arrow_picker || exit 0
  else
    print_local_rooms local
    echo
    printf 'Room number or name (q to quit): '
    read -r choice || exit 0
    [[ "$choice" == "q" || "$choice" == "Q" ]] && exit 0
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
      ((choice >= 1 && choice <= ${#rows[@]})) || { echo "Invalid room number."; exit 2; }
      IFS='|' read -r target _ <<<"${rows[$((choice-1))]}"
    else
      target="$choice"
    fi
  fi

  echo
  print_room_details "$target" || exit $?
  echo
  printf 'Attach this room? [y/N]: '
  read -r attach_choice || attach_choice=""
  case "$attach_choice" in
    y|Y|yes|YES) ;;
    *) echo "Attachment cancelled."; exit 0 ;;
  esac

  current_identity=$(tmux display-message -p -t "=$target" '#{session_id}|#{session_name}' 2>/dev/null || true)
  if [[ "$current_identity" != "$selected_session_id|$target" ]]; then
    echo "Attachment aborted: room identity changed after inspection."
    exit 1
  fi
fi

if [[ -n "$selected_session_id" ]]; then
  attach_target="$selected_session_id"
else
  attach_target="=$target"
fi

if ! tmux has-session -t "$attach_target" 2>/dev/null; then
  echo "Room not found: $target"
  exit 1
fi

echo "Attaching to $target. Detach with Ctrl-b then d."
exec tmux attach-session -t "$attach_target"
